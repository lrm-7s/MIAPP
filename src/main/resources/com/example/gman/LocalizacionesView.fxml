<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600" prefWidth="900"
            xmlns="http://javafx.com/javafx/16"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gman.presentation.controller.LocalizacionesController">

    <VBox AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          spacing="0">

        <!-- HEADER -->
        <HBox styleClass="modulo-header"
              alignment="CENTER_LEFT"
              spacing="16">

            <VBox spacing="4" HBox.hgrow="ALWAYS">

                <Label text="Gestión de Localizaciones"
                       styleClass="modulo-titulo"/>

                <Label text="Administre las localizaciones del sistema"
                       styleClass="modulo-subtitulo"/>

            </VBox>

        </HBox>

        <!-- CUERPO -->
        <VBox styleClass="modulo-body"
              spacing="10"
              VBox.vgrow="ALWAYS">

            <VBox fx:id="panelFormulario"
                  spacing="14"
                  VBox.vgrow="ALWAYS">

                <Label fx:id="lblTituloForm"
                       text="Listado de Localizaciones"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"
                       styleClass="texto-logo"/>

                <!-- TABLA -->
                <TableView fx:id="tablaLocalizaciones" VBox.vgrow="ALWAYS">

                    <columns>

                        <TableColumn fx:id="colNumero"
                                     text="N° Localización"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colDescripcion"
                                     text="Descripción"
                                     prefWidth="300"/>

                        <TableColumn fx:id="colDepartamento"
                                     text="Departamento"
                                     prefWidth="200"/>

                    </columns>

                </TableView>

                <!-- BOTONES OPCIONALES -->
                <HBox spacing="10">
                    <Button text="Nuevo" fx:id="btnNuevo"/>
                    <Button text="Editar" fx:id="btnEditar"/>
                    <Button text="Eliminar" fx:id="btnEliminar"/>
                </HBox>

            </VBox>

        </VBox>

    </VBox>

    <!-- FOOTER -->
    <Label text="GMAN"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"
           AnchorPane.bottomAnchor="10"
           AnchorPane.rightAnchor="10"/>

</AnchorPane>