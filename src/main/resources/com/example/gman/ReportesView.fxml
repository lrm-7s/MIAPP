<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600" prefWidth="900" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.gman.presentation.controller.ReportesController">

    <VBox spacing="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="modulo-header">

            <VBox spacing="4" HBox.hgrow="ALWAYS">

                <Label styleClass="modulo-titulo" text="Gestión de Reportes" />

                <Label styleClass="modulo-subtitulo" text="Visualice y ejecute reportes del sistema" />
                <HBox alignment="CENTER_LEFT">

                    <!-- empuja el botón hacia la derecha -->
                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="btnVistaPreliminar" text="Vista Preliminar" />

                </HBox>

            </VBox>

        </HBox>

        <!-- CUERPO -->
        <VBox spacing="10" styleClass="modulo-body" VBox.vgrow="ALWAYS">

            <VBox spacing="14" VBox.vgrow="ALWAYS">

                <!-- TÍTULO + BOTÓN AL BORDE DERECHO -->


                <!-- TABLA -->
                <TableView fx:id="tablaReportes" VBox.vgrow="ALWAYS">

                    <columns>
                        <TableColumn fx:id="ColId" prefWidth="200" text="Grupo de Reporte" />

                        <TableColumn fx:id="colGrupo" prefWidth="200" text="Grupo de Reporte" />

                        <TableColumn fx:id="colNombre" prefWidth="350" text="Nombre del Reporte" />

                        <TableColumn fx:id="colVistaPrevia" prefWidth="180" text="Vista Preliminar" />

                    </columns>

                </TableView>

            </VBox>

        </VBox>

    </VBox>

    <!-- FOOTER -->
    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="GMAN" AnchorPane.bottomAnchor="10" AnchorPane.rightAnchor="10" />

</AnchorPane>
