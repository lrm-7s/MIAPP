<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600" prefWidth="900"
            xmlns="http://javafx.com/javafx/16"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gman.presentation.controller.ReportesController">

    <VBox spacing="0"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT"
              spacing="16"
              styleClass="modulo-header">

            <VBox spacing="4" HBox.hgrow="ALWAYS">

                <Label text="Gestión de Reportes"
                       styleClass="modulo-titulo"/>

                <Label text="Visualice y ejecute reportes del sistema"
                       styleClass="modulo-subtitulo"/>
                <HBox alignment="CENTER_LEFT">

                    <!-- empuja el botón hacia la derecha -->
                    <Region HBox.hgrow="ALWAYS"/>

                    <Button fx:id="btnVistaPreliminar"
                            text="Vista Preliminar"/>

                </HBox>

            </VBox>

        </HBox>

        <!-- CUERPO -->
        <VBox spacing="10"
              styleClass="modulo-body"
              VBox.vgrow="ALWAYS">

            <VBox spacing="14" VBox.vgrow="ALWAYS">

                <!-- TÍTULO + BOTÓN AL BORDE DERECHO -->


                <!-- TABLA -->
                <TableView fx:id="tablaReportes"
                           VBox.vgrow="ALWAYS">

                    <columns>
                        <TableColumn fx:id="ColId"
                                     text="Grupo de Reporte"
                                     prefWidth="200"/>

                        <TableColumn fx:id="colGrupo"
                                     text="Grupo de Reporte"
                                     prefWidth="200"/>

                        <TableColumn fx:id="colNombre"
                                     text="Nombre del Reporte"
                                     prefWidth="350"/>

                        <TableColumn fx:id="colVistaPrevia"
                                     text="Vista Preliminar"
                                     prefWidth="180"/>

                    </columns>

                </TableView>

            </VBox>

        </VBox>

    </VBox>

    <!-- FOOTER -->
    <Label text="GMAN"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"
           AnchorPane.bottomAnchor="10"
           AnchorPane.rightAnchor="10"/>

</AnchorPane>