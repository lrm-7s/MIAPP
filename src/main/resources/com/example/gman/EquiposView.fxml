<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  EquiposView.fxml — Cambios respecto a la versión anterior:
    1. colPlanta      → colLocalizacion  (fx:id y texto "Localización")
    2. cbPlanta       → cbLocalizacion   (fx:id y promptText)
    3. ComboBox cbArea, cbLocalizacion, cbCriticidad, cbTipo
       ya NO son editables — los valores vienen del catálogo, no son libres.
-->

<AnchorPane
            xmlns="http://javafx.com/javafx/16"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gman.presentation.controller.EquiposController"
            styleClass="content-area">

    <VBox AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          spacing="0">

        <!-- ═══════════════════ HEADER ═══════════════════ -->
        <HBox styleClass="modulo-header"
              alignment="CENTER_RIGHT"
              spacing="0">

            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Gestión de Equipos"
                       styleClass="modulo-titulo"/>
                <Label fx:id="lblTotalEquipos"
                       text="Total: 0"
                       styleClass="modulo-subtitulo"/>
            </VBox>

            <Button fx:id="btnAgregar"
                    styleClass="btn-primario"
                    text="+ Agregar">
                <tooltip><Tooltip text="Nuevo Equipo"/></tooltip>
            </Button>

        </HBox>

        <!-- ═══════════════════ CUERPO ═══════════════════ -->
        <VBox styleClass="modulo-body"
              spacing="10"
              VBox.vgrow="ALWAYS">

            <!-- ─────────── PANEL LISTA ─────────── -->
            <VBox fx:id="panelLista"
                  spacing="8"
                  VBox.vgrow="ALWAYS">

                <!-- Buscador -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="busquedaField"
                               promptText="Buscar por código, nombre, marca, área…"
                               styleClass="campo-input"
                               HBox.hgrow="ALWAYS"
                               onKeyReleased="#filtrarEquipos"/>
                </HBox>

                <!-- Tabla -->
                <TableView fx:id="tableEquipos"
                           VBox.vgrow="ALWAYS"
                           styleClass="tabla-datos">
                    <columns>
                        <TableColumn fx:id="colNumero"
                                     text="N°"
                                     prefWidth="40"
                                     resizable="false"/>
                        <!-- colId oculto: se usa internamente -->
                        <TableColumn fx:id="colId"
                                     prefWidth="0"
                                     minWidth="0"
                                     maxWidth="0"
                                     visible="false"/>
                        <TableColumn fx:id="colCodigo"      text="Código"           prefWidth="80"/>
                        <TableColumn fx:id="colNombre"      text="Nombre"           prefWidth="120"/>
                        <TableColumn fx:id="colCapacidad"   text="Capacidad"        prefWidth="80"/>
                        <TableColumn fx:id="colMarca"       text="Marca"            prefWidth="80"/>
                        <TableColumn fx:id="colModelo"      text="Modelo"           prefWidth="80"/>
                        <TableColumn fx:id="colSerie"       text="Serie"            prefWidth="80"/>
                        <TableColumn fx:id="colArea"        text="Área"             prefWidth="90"/>

                        <!-- CORREGIDO: antes colPlanta → ahora colLocalizacion -->
                        <TableColumn fx:id="colLocalizacion" text="Localización"    prefWidth="110"/>

                        <TableColumn fx:id="colCentro"      text="Centro Costos"    prefWidth="100"/>
                        <TableColumn fx:id="colCriticidad"  text="Criticidad"       prefWidth="80"/>
                        <TableColumn fx:id="colTipo"        text="Tipo"             prefWidth="90"/>
                        <TableColumn fx:id="colAcciones"    text="Acciones"         prefWidth="90"
                                     resizable="false"/>
                    </columns>

                    <placeholder>
                        <Label text="No hay equipos registrados."/>
                    </placeholder>
                </TableView>

            </VBox>

            <!-- ─────────── FORMULARIO ─────────── -->
            <VBox fx:id="panelFormulario"
                  managed="false"
                  visible="false"
                  spacing="14">

                <Label fx:id="lblTituloForm"
                       text="Nuevo Equipo"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"
                       styleClass="texto-logo"/>

                <GridPane hgap="12" vgap="12">

                    <!-- Fila 0: Código | Nombre | Capacidad -->
                    <TextField fx:id="tfCodigo"
                               promptText="Código *"
                               styleClass="campo-input"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfNombre"
                               promptText="Nombre *"
                               styleClass="campo-input"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfCapacidad"
                               promptText="Capacidad"
                               styleClass="campo-input"
                               GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                    <!-- Fila 1: Marca | Modelo | Serie -->
                    <TextField fx:id="tfMarca"
                               promptText="Marca"
                               styleClass="campo-input"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="tfModelo"
                               promptText="Modelo"
                               styleClass="campo-input"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <TextField fx:id="tfSerie"
                               promptText="Serie / Placa"
                               styleClass="campo-input"
                               GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                    <!-- Fila 2: Área | Localización | Centro de Costos -->
                    <!--
                        CORREGIDO:
                          cbArea y cbLocalizacion no son editables.
                          cbPlanta fue renombrado a cbLocalizacion.
                    -->
                    <ComboBox fx:id="cbArea"
                              promptText="Área *"
                              maxWidth="Infinity"
                              GridPane.columnIndex="0" GridPane.rowIndex="2"/>

                    <ComboBox fx:id="cbLocalizacion"
                              promptText="Localización (Planta)"
                              maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <TextField fx:id="tfCentro"
                               promptText="Centro de Costos"
                               styleClass="campo-input"
                               GridPane.columnIndex="2" GridPane.rowIndex="2"/>

                    <!-- Fila 3: Criticidad | Tipo -->
                    <ComboBox fx:id="cbCriticidad"
                              promptText="Criticidad *"
                              maxWidth="Infinity"
                              GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                    <ComboBox fx:id="cbTipo"
                              promptText="Tipo de Equipo *"
                              maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <!-- Fila 4: Botones -->
                    <HBox spacing="10"
                          GridPane.columnIndex="0"
                          GridPane.columnSpan="3"
                          GridPane.rowIndex="4">
                        <Button fx:id="btnRetroceder" text="⬅ Volver"/>
                        <Button fx:id="btnGuardar"
                                text="Guardar"
                                styleClass="btn-primario"
                                style="-fx-font-weight: bold;"/>
                    </HBox>

                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="34"/>
                    </columnConstraints>

                    <rowConstraints>
                        <RowConstraints minHeight="38"/>
                        <RowConstraints minHeight="38"/>
                        <RowConstraints minHeight="38"/>
                        <RowConstraints minHeight="38"/>
                        <RowConstraints minHeight="44"/>
                    </rowConstraints>

                </GridPane>

            </VBox>

        </VBox>

        <!-- FOOTER -->
        <Label text="GMAN"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    </VBox>

</AnchorPane>
