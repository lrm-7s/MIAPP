<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gman.presentation.controller.MainMenuController">

   <!-- ═══════════════════════════════════════
        TOP — Barra de menú superior
   ═══════════════════════════════════════ -->
   <top>
      <VBox>
         <MenuBar prefHeight="34.0" prefWidth="600.0">

            <Menu text="Archivo">
               <MenuItem onAction="#logout" text="Cerrar Sesión" />
               <MenuItem onAction="#exitApp" text="Salir" />
            </Menu>

            <Menu text="Módulos">
               <MenuItem onAction="#openEquipos"           text="Equipos" />
               <MenuItem onAction="#openEmpleados"         text="Empleados" />
               <MenuItem onAction="#openOrdenTrabajo"      text="Orden de Trabajo" />
               <MenuItem onAction="#openReportes"          text="Reportes" />
               <MenuItem onAction="#openCatalogo"          text="Catálogo" />
               <MenuItem onAction="#openPlanMantenimiento" text="Plan de Mantenimiento" />
               <MenuItem onAction="#openHistorico"         text="Histórico" />
               <MenuItem onAction="#openLocalizaciones"    text="Localizaciones" />
               <MenuItem         text="Inventario" />
               <SeparatorMenuItem />
               <MenuItem onAction="#openGestionUsuarios"   text="Gestión de Usuarios" />
            </Menu>

            <Menu text="Ayuda">
               <MenuItem onAction="#openAbout" text="Acerca de" />
            </Menu>

         </MenuBar>
      </VBox>
   </top>

   <!-- ═══════════════════════════════════════
        LEFT — Sidebar
   ═══════════════════════════════════════ -->
   <left>
      <VBox prefWidth="200" spacing="0" styleClass="sidebar">

         <!-- LOGO -->
         <VBox alignment="CENTER" spacing="2" styleClass="sidebar-logo">
            <Label styleClass="texto-logo" text="GMAN" />
            <Label styleClass="sidebar-subtitulo" text="Gestión de Mantenimiento" />
         </VBox>

         <!-- INFO DEL USUARIO EN SESIÓN -->
         <VBox prefHeight="18.0" prefWidth="200.0" spacing="4" styleClass="sidebar-usuario">
            <Label styleClass="sidebar-label-pequeno" text="Usuario:" />
            <Label fx:id="lblUsuario" styleClass="sidebar-nombre-usuario" text="—" />
            <Label fx:id="lblRol"     styleClass="sidebar-rol-usuario"    text="—" />
         </VBox>

         <Separator prefWidth="200.0" />

         <!-- BOTONES DE MÓDULOS -->
         <VBox spacing="4" styleClass="sidebar-menu" VBox.vgrow="ALWAYS">

            <Button fx:id="btnEquipos" maxWidth="Infinity"
                    onAction="#openEquipos" styleClass="menu-btn" text="⚙  Equipos">
               <tooltip><Tooltip text="Gestión de Equipos" /></tooltip>
            </Button>

            <Button fx:id="btnEmpleados" maxWidth="Infinity"
                    onAction="#openEmpleados" styleClass="menu-btn" text="👷  Mano de Obra">
               <tooltip><Tooltip text="Gestión de Mano de Obra" /></tooltip>
            </Button>

            <Button fx:id="btnOrdenTrabajo" maxWidth="Infinity"
                    onAction="#openOrdenTrabajo" styleClass="menu-btn" text="📋  Orden de Trabajo">
               <tooltip><Tooltip text="Gestión de Órdenes de Trabajo" /></tooltip>
            </Button>

            <Button fx:id="btnReportes" maxWidth="Infinity"
                    onAction="#openReportes" styleClass="menu-btn" text="📊  Reportes">
               <tooltip><Tooltip text="Ver Reportes" /></tooltip>
            </Button>

            <Button fx:id="btnCatalogo" maxWidth="Infinity"
                    onAction="#openCatalogo" styleClass="menu-btn" text="📁  Catálogo">
               <tooltip><Tooltip text="Gestión de Catálogos" /></tooltip>
            </Button>

            <Button fx:id="btnPlanMantenimiento" maxWidth="Infinity"
                    onAction="#openPlanMantenimiento" styleClass="menu-btn" text="🗓  Plan Mantenimiento">
               <tooltip><Tooltip text="Plan de Mantenimiento" /></tooltip>
            </Button>

            <Button fx:id="btnHistorico" maxWidth="Infinity"
                    onAction="#openHistorico" styleClass="menu-btn" text="🕐  Histórico">
               <tooltip><Tooltip text="Ver Histórico" /></tooltip>
            </Button>

            <Button fx:id="btnLocalizaciones" maxWidth="Infinity"
                    onAction="#openLocalizaciones" styleClass="menu-btn" text="📍  Localizaciones">
               <tooltip><Tooltip text="Gestión de Localizaciones" /></tooltip>
            </Button>

            <Separator />
            <Button fx:id="btnInventario" maxWidth="Infinity"
                    onAction="#openInventario" styleClass="menu-btn" text="📄 Inventario">
               <tooltip><Tooltip text="Gestión de Equipos" /></tooltip>
            </Button>

            <!-- Solo visible para ADMIN -->
            <Button fx:id="btnGestionUsuarios" maxWidth="Infinity"
                    onAction="#openGestionUsuarios"
                    styleClass="menu-btn menu-btn-admin" text="👥  Gestión de Usuarios">
               <tooltip><Tooltip text="Administrar Usuarios y Roles" /></tooltip>
            </Button>

            <!-- Empleados — visibilidad controlada por rol -->

         </VBox>

         <!-- BOTÓN CERRAR SESIÓN al fondo -->
         <VBox spacing="4" styleClass="sidebar-footer">
            <Separator />
            <Button maxWidth="Infinity" onAction="#logout"
                    styleClass="menu-btn-logout" text="🚪  Cerrar Sesión" />
         </VBox>

      </VBox>
   </left>

   <!-- ═══════════════════════════════════════
        CENTER — Contenido principal
   ═══════════════════════════════════════ -->
   <center>
      <AnchorPane fx:id="contentPane" prefHeight="416.0" prefWidth="465.0"
                  styleClass="content-area"
                  AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                  AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />
   </center>

   <!-- ═══════════════════════════════════════
        BOTTOM — Barra de estado
   ═══════════════════════════════════════ -->
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="16" styleClass="status-bar">
         <Label styleClass="status-label"     text="GMAN v1.0" />
         <Label styleClass="status-separador" text="|" />
         <Label styleClass="status-label"     text="Sistema de Gestión de Mantenimiento" />
      </HBox>
   </bottom>

</BorderPane>
