<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600" prefWidth="900"
            xmlns="http://javafx.com/javafx/16"
            xmlns:fx="http://javafx.com/fxml/1"
            >

    <VBox AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          spacing="0">

        <!-- ═════════ HEADER (igual a Usuarios) ═════════ -->
        <HBox styleClass="modulo-header"
              alignment="CENTER_LEFT"
              spacing="16">

            <VBox spacing="4" HBox.hgrow="ALWAYS">

                <Label text="Gestión de Localizaciones"
                       styleClass="modulo-titulo"/>

                <Label text="Administre las localizaciones del sistema"
                       styleClass="modulo-subtitulo"/>

            </VBox>

        </HBox>

        <!-- ═════════ CUERPO ═════════ -->
        <VBox styleClass="modulo-body"
              spacing="10"
              VBox.vgrow="ALWAYS">

            <!-- FORMULARIO (NO MODIFICADO) -->
            <VBox fx:id="panelFormulario"
                  spacing="14"
                  VBox.vgrow="ALWAYS">

                <Label fx:id="lblTituloForm"
                       text="Nueva Localización"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"
                       styleClass="texto-logo"/>

                <GridPane hgap="10" vgap="10">

                    <!-- FILA 1 -->
                    <TextField fx:id="tfNumeroLocalizaciones"
                               promptText="Número de Localizaciones"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="0"/>

                    <TextField fx:id="cbDescripcion"
                              promptText="Descripción"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="0"/>

                    <ComboBox fx:id="cbDepartamento"
                              promptText="Departamento"
                              GridPane.columnIndex="2"
                              GridPane.rowIndex="0"/>

                    <!-- FILA 2 -->
                    <TextArea fx:id="taNotasLocalizaciones"
                              promptText="Notas"
                              prefRowCount="3"
                              wrapText="true"
                              GridPane.columnIndex="0"
                              GridPane.rowIndex="1"
                              GridPane.columnSpan="3"/>

                    <!-- BOTONES -->
                    <HBox spacing="10"
                          GridPane.columnIndex="0"
                          GridPane.columnSpan="3"
                          GridPane.rowIndex="3">

                        <Button fx:id="btnRetroceder" text="⬅">
                            <tooltip>
                                <Tooltip text="Volver al menú anterior"/>
                            </tooltip>
                        </Button>

                        <Button fx:id="btnGuardar"
                                text="Guardar"
                                style="-fx-font-weight: bold;">
                            <tooltip>
                                <Tooltip text="Guardar Localización"/>
                            </tooltip>
                        </Button>

                    </HBox>

                    <!-- COLUMNAS -->
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <!-- FILAS -->
                    <rowConstraints>
                        <RowConstraints minHeight="35"/>
                        <RowConstraints minHeight="35"/>
                        <RowConstraints minHeight="40"/>
                        <RowConstraints minHeight="40"/>
                    </rowConstraints>

                </GridPane>

            </VBox>

        </VBox>


    </VBox>

    <!-- FOOTER (simplificado como en otros módulos) -->
    <Label text="GMAN"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"
           AnchorPane.bottomAnchor="10"
           AnchorPane.rightAnchor="10"/>

</AnchorPane>