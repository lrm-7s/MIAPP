<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefWidth="900" prefHeight="600"
            xmlns="http://javafx.com/javafx/16"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gman.presentation.controller.OrdenTrabajoController">

    <VBox spacing="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- HEADER -->
        <HBox styleClass="modulo-header" alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Órdenes de Trabajo" styleClass="modulo-titulo"/>
                <Label text="Gestione las órdenes de trabajo del sistema" styleClass="modulo-subtitulo"/>
            </VBox>
        </HBox>

        <!-- BARRA DE HERRAMIENTAS -->
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-padding: 10 16 10 16; -fx-background-color: #f5f5f5; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">

            <!-- Búsqueda -->
            <TextField fx:id="busquedaField" promptText="Buscar por N° OT, descripción, estado..."
                       prefWidth="280" onKeyReleased="#filtrarOrdenes"/>

            <!-- Filtro por estado -->
            <ComboBox fx:id="cbFiltroEstado" promptText="Todos los estados"
                      prefWidth="160" onAction="#filtrarPorEstado"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Botones principales -->
            <Button fx:id="btnNuevaOT"  text="Nueva OT"  onAction="#nuevaOT"
                    styleClass="btn-primario"/>
            <Button fx:id="btnVerEditar" text="Ver / Editar" onAction="#verEditarOT"
                    styleClass="btn-secundario"/>
            <Button fx:id="btnCerrarOT" text="Cerrar OT"  onAction="#cerrarOT"
                    styleClass="btn-secundario"/>
        </HBox>

        <!-- MENSAJE -->
        <Label fx:id="mensajeLabel" visible="false" managed="false"
               style="-fx-padding: 6 16; -fx-font-size: 13px;"/>

        <!-- TABLA -->
        <TableView fx:id="tableOT" VBox.vgrow="ALWAYS"
                   style="-fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colNumero"      text="N° OT"                prefWidth="130"/>
                <TableColumn fx:id="colTipo"        text="Tipo OT"              prefWidth="110"/>
                <TableColumn fx:id="colEstado"      text="Estado"               prefWidth="100"/>
                <TableColumn fx:id="colDescripcion" text="Descripción del trabajo" prefWidth="280"/>
                <TableColumn fx:id="colPrioridad"   text="Prioridad"            prefWidth="90"/>
                <TableColumn fx:id="colFecha"       text="Fecha solicitud"      prefWidth="130"/>
                <TableColumn fx:id="colAcciones"    text="Acciones"             prefWidth="100"/>
            </columns>
            <placeholder><Label text="No hay órdenes de trabajo registradas."/></placeholder>
        </TableView>

        <!-- FOOTER -->
        <HBox alignment="CENTER_RIGHT" spacing="10"
              style="-fx-padding: 8 16; -fx-background-color: #f5f5f5;">
            <Label fx:id="lblTotal" text="Total: 0 órdenes"
                   style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
        </HBox>

    </VBox>

    <Label text="GMAN"
           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ccc;"
           AnchorPane.bottomAnchor="6" AnchorPane.rightAnchor="10"/>
</AnchorPane>